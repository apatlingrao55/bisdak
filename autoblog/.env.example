# bisdak-autoblog environment — copy to .env and chmod 600.
# All values are required unless marked OPTIONAL.

# ── Postgres (bisdak's Supabase) ─────────────────────────────────────────────
# Same DATABASE_URL the Vercel app uses. Pooler URL on port 6543; the publisher
# disables server-side prepared statements automatically.
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:6543/postgres

# ── Resend (operator notifications) ──────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=hello@mail.bisdak.co.nz
NOTIFY_EMAIL=hello@bisdak.co.nz

# ── BisDak site URL (used in admin links emailed to the operator) ───────────
SITE_URL=https://bisdak.co.nz

# ── Kill switches (default: both ON) ─────────────────────────────────────────
# Set to "false" to halt the relevant pipeline stage without removing cron entries.
# When AUTOBLOG_PUBLISH_ENABLED=false, the pipeline still generates + reviews
# the draft and emails it to the operator — it just doesn't INSERT into Postgres.
AUTOBLOG_DISCOVER_ENABLED=true
AUTOBLOG_PUBLISH_ENABLED=true

# ── OPTIONAL: override the SQLite DB path (default: $AUTOBLOG_BASE_DIR/data/bisdak_autoblog.sqlite)
# AUTOBLOG_DB_PATH=
